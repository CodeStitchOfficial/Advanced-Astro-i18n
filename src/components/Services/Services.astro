<style lang="less">
@media only screen and (min-width: 0rem) {
    #services-2279 {
        padding: var(--sectionPadding);
        position: relative;
        z-index: 1;
    }
    #services-2279:before {
        background-color: #001200;
        content: "";
        display: block;
        height: clamp(37.5rem,70vw,42rem);
        left: 0;
        position: absolute;
        top: 0;
        transition: background-color .3s;
        width: 100%;
        z-index: -1;
    }
    #services-2279 .cs-container {
        gap: clamp(3rem,6vw,4rem);
        margin: auto;
        max-width: 34.375rem;
    }
    #services-2279 .cs-container,
    #services-2279 .cs-content {
        align-items: center;
        display: flex;
        flex-direction: column;
        width: 100%;
    }
    #services-2279 .cs-content {
        max-width: 50rem;
        text-align: center;
    }
    #services-2279 .cs-content .cs-text {
        color: var(--bodyTextColorWhite);
        margin-bottom: 1em;
    }
    #services-2279 .cs-title {
        color: var(--bodyTextColorWhite);
        margin: 0 0 .5em;
        max-width: 18ch;
    }

    #services-2279 .cs-text {
        opacity: .8;
    }
    #services-2279 .cs-card-group {
        display: grid;
        gap: clamp(.5rem,2vw,1.25rem);
        grid-template-columns: repeat(12,1fr);
        margin: 0;
        padding: 0;
        width: 100%;
    }
    #services-2279 .cs-item {
        --itemPadding: clamp(1.5rem,3.5vw,3rem);
        align-items: flex-start;
        background-color: #fff;
        border: 1px solid #e7e7e8;
        border-radius:0 2rem;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        grid-column: span 12;
        grid-row: span 1;
        justify-content: center;
        list-style: none;
        margin: 0;
        padding: var(--itemPadding);
        position: relative;
        text-align: left;
        width: 100%;
        z-index: 1;
    }
    #services-2279 .cs-item:hover .cs-h3,
    #services-2279 .cs-item:hover .cs-item-text,
    #services-2279 .cs-item:hover .cs-link {
        color: var(--bodyTextColorWhite);
    }
    #services-2279 .cs-item:hover .cs-item-text {
        opacity: .9;
    }
    #services-2279 .cs-item:hover .cs-icon-wrapper {
        border-radius: 50% 0;
        transform: rotate(90deg);
    }
    #services-2279 .cs-item:hover .cs-icon {
        transform: rotate(-90deg);
    }
    #services-2279 .cs-item:hover .cs-arrow {
        filter: grayscale(1) brightness(10000%);
    }
    #services-2279 .cs-item:hover .cs-background {
        opacity: 1;
    }
    #services-2279 .cs-icon-wrapper {
        align-items: center;
        background-color: #fff;
        bottom: var(--itemPadding);
        display: flex;
        height: clamp(3rem,7vw,6.25rem);
        justify-content: center;
        margin: 0;
        overflow: hidden;
        position: absolute;
        right: var(--itemPadding);
        transition: transform .5s,border-radius .5s;
        width: clamp(3rem,7vw,6.25rem);
        z-index: 1;
    }
    #services-2279 .cs-icon-wrapper:before {
        background: var(--primary);
        content: "";
        display: block;
        height: 100%;
        left: 0;
        opacity: .1;
        position: absolute;
        top: 0;
        width: 100%;
        z-index: -1;
    }
    #services-2279 .cs-icon {
        height: auto;
        transition: transform .5s;
        width: clamp(1.5rem,4vw,3rem);
    }
    #services-2279 .cs-h3 {
        align-items: center;
        color: var(--headerColor);
        display: flex;
        font-size: clamp(1.25rem,2.5vw,1.5625rem);
        gap: 1rem;
        line-height: 1.2em;
        margin: 0 0 .75rem;
        position: relative;
        text-align: inherit;
        z-index: 1;
    }
    #services-2279 .cs-h3:before {
        background: var(--primary);
        content: "";
        display: block;
        height: .5rem;
        opacity: 1;
        width: .5rem;
    }
    #services-2279 .cs-item-text {
        color: var(--bodyTextColor);
        font-size: 1rem;
        line-height: 1.5em;
        margin: 0 0 clamp(3.5rem,8vw,6.75rem);
        max-width: 18.75rem;
        padding: 0;
    }
    #services-2279 .cs-link {
        color: var(--headerColor);
        display: inline-flex;
        font-family: var(--headerFont);
        font-size: 1rem;
        gap: .75rem;
        justify-content: space-between;
        line-height: 1.2em;
        margin: 0;
        padding: 0 0 .375rem;
        position: relative;
        text-decoration: none;
        text-transform: uppercase;
        transition: color .3s;
    }
    #services-2279 .cs-link:hover .cs-arrow {
        transform: rotate(45deg);
    }
    #services-2279 .cs-link:before {
        background: currentColor;
        bottom: 0;
        content: "";
        display: block;
        height: 1px;
        left: 0;
        opacity: 1;
        position: absolute;
        width: 100%;
    }
    #services-2279 .cs-arrow {
        display: block;
        height: auto;
        transition: transform .3s;
        width: 1.25rem;
    }
    #services-2279 .cs-background {
        border-radius: 0 2rem;
        opacity: 0;
        overflow: hidden;
        transition: opacity .3s;
        z-index: -1;
    }
    #services-2279 .cs-background,
    #services-2279 .cs-background:before {
        display: block;
        height: 100%;
        left: 0;
        position: absolute;
        top: 0;
        width: 100%;
    }
    #services-2279 .cs-background:before {
        background: var(--dark);
        content: "";
        opacity: .84;
        z-index: 1;
    }
    #services-2279 .cs-background img {
        height: 100%;
        left: 0;
        -o-object-fit: cover;
        object-fit: cover;
        position: absolute;
        top: 0;
        width: 100%;
    }
    #services-2279 .cs-accent {
        display: block;
        height: 21.6875rem;
        left: 0;
        position: absolute;
        top: 0;
        width: 100%;
        z-index: -1;
    }
    #services-2279 .cs-accent:before {
        background: #111418;
        content: "";
        display: block;
        height: 100%;
        left: 0;
        opacity: 1;
        position: absolute;
        top: 0;
        width: 100%;
        z-index: -2;
    }
    #services-2279 .cs-accent img {
        height: 100%;
        left: 0;
        mix-blend-mode: soft-light;
        -o-object-fit: cover;
        object-fit: cover;
        opacity: .24;
        position: absolute;
        top: 0;
        width: 100%;
    }
}

@media only screen and (min-width: 48rem) {
    #services-2279 .cs-container {
        max-width:80rem;
    }
    #services-2279 .cs-container .cs-text {
        text-align: left;
    }
    #services-2279 .cs-item {
        grid-column: span 6;
        justify-content: flex-start;
    }
    #services-2279 .cs-link {
        margin-top: auto;
    }
}

@media only screen and (min-width: 64rem) {
    #services-2279 .cs-item {
        grid-column:span 4;
    }
    #services-2279 .cs-accent {
        height: clamp(27.1875rem,41vw,32.875rem);
    }
}

@media only screen and (min-width: 0rem) {
    body.dark-mode #services-2279:before {
        background-color:#000c00;
    }
    body.dark-mode #services-2279 .cs-item {
        background-color: var(--dark);
        border-color: hsla(0,0%,100%,.2);
    }
    body.dark-mode #services-2279 .cs-item:hover .cs-icon-wrapper:before {
        background-color: var(--primary);
        opacity: .9;
    }
    body.dark-mode #services-2279 .cs-h3,
    body.dark-mode #services-2279 .cs-item-text,
    body.dark-mode #services-2279 .cs-link {
        color: var(--bodyTextColorWhite);
    }
    body.dark-mode #services-2279 .cs-icon-wrapper {
        background-color: var(--dark);
    }
    body.dark-mode #services-2279 .cs-icon-wrapper:before {
        background-color: #000;
        opacity: .3;
        transition: background-color .3s,opacity .3s;
    }
    body.dark-mode #services-2279 .cs-arrow,
    body.dark-mode #services-2279 .cs-icon {
        filter: grayscale(1) brightness(10000%);
    }
}

</style>
