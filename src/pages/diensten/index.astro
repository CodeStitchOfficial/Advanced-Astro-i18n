---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
	title="Onze diensten — webdesign, development en SEO voor het MKB"
	description="nise.nl biedt handgemaakte websites, technische SEO en directe ondersteuning voor het MKB. Geen WordPress, geen grote bureaus — persoonlijk en doeltreffend."
>

<!-- ============================================ -->
<!--                   Banner                     -->
<!-- ============================================ -->

<div id="banner-843">
    <div class="cs-container">
        <span class="cs-int-title">Onze diensten</span>
    </div>
    <picture class="cs-background" aria-hidden="true">
        <source media="(max-width: 600px)" srcset="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images%2FPeople%2Fyoga-m.jpg">
        <source media="(min-width: 601px)" srcset="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images%2FPeople%2Fyoga.jpg">
        <img loading="lazy" decoding="async" src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images%2FPeople%2Fyoga.jpg" alt="diensten nise.nl" width="1280" height="568">
    </picture>
    <svg class="cs-wave" width="1920" height="179" viewBox="0 0 1920 179" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" clip-rule="evenodd" d="M1920 179V91.3463C1835.33 91.3463 1715.47 76.615 1549.2 32.9521C1299.48 -32.3214 1132.77 12.1006 947.32 61.5167C810.762 97.9044 664.042 137 466.533 137C331.607 137 256.468 123.447 188.082 111.113C130.974 100.812 78.5746 91.3609 0 91.3609V179H1920Z" fill="white"/>
    </svg>
</div>

<!-- ============================================ -->
<!--                 Diensten                     -->
<!-- ============================================ -->

<section id="diensten-overview">
    <div class="cs-container">
        <div class="cs-content">
            <span class="cs-topper">Wat wij doen</span>
            <h2 class="cs-title">Alles wat je nodig hebt voor een sterke online aanwezigheid</h2>
            <p class="cs-text">
                Van het eerste ontwerp tot de lancering en daarna: wij zorgen dat jouw website goed werkt, goed gevonden wordt en goed bijgehouden wordt.
            </p>
        </div>
        <ul class="cs-card-group">
            <li class="cs-item">
                <a href="/diensten/web-development/" class="cs-link">
                    <h3 class="cs-h3">Webdesign &amp; Development</h3>
                    <p class="cs-item-text">
                        Handgemaakte websites zonder WordPress. Razendsnel, veilig en volledig op maat voor jouw bedrijf.
                    </p>
                    <span class="cs-cta">Meer informatie &rarr;</span>
                </a>
            </li>
            <li class="cs-item">
                <a href="/diensten/seo/" class="cs-link">
                    <h3 class="cs-h3">Zoekmachineoptimalisatie (SEO)</h3>
                    <p class="cs-item-text">
                        Hoger ranken in Google. Technische SEO-basis standaard inbegrepen — aanvullende diensten op aanvraag.
                    </p>
                    <span class="cs-cta">Meer informatie &rarr;</span>
                </a>
            </li>
            <li class="cs-item">
                <a href="/contact/" class="cs-link">
                    <h3 class="cs-h3">Onderhoud &amp; Support</h3>
                    <p class="cs-item-text">
                        Onbeperkte aanpassingen via het Partner-abonnement. Bel of mail ons — wij regelen het dezelfde dag.
                    </p>
                    <span class="cs-cta">Neem contact op &rarr;</span>
                </a>
            </li>
        </ul>
    </div>
</section>

</BaseLayout>

<style lang="less">
/*-- -------------------------- -->
<---          Banner            -->
<--- -------------------------- -*/

@media only screen and (min-width: 0rem) {
    #banner-843 {
        padding: clamp(10.9375rem, 20vw, 16.25rem) (16/16rem) clamp(6.25rem, 14vw, 12vw);
        overflow: hidden;
        position: relative;
        z-index: 1;

        .cs-container {
            text-align: center;
            width: 100%;
            max-width: (1280/16rem);
            margin: auto;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: flex-start;
            gap: (16/16rem);
        }

        .cs-int-title {
            font-size: clamp(2.4375rem, 6.4vw, 3.8125rem);
            font-weight: 900;
            line-height: 1.2em;
            margin: 0;
            color: var(--bodyTextColorWhite);
        }

        .cs-background {
            width: 100%;
            height: 100%;
            display: block;
            position: absolute;
            top: 0;
            left: 0;
            z-index: -1;

            &:before {
                content: "";
                position: absolute;
                display: block;
                height: 100%;
                width: 100%;
                background: #1a1a1a;
                opacity: 0.64;
                top: 0;
                left: 0;
                z-index: 1;
            }

            img {
                position: absolute;
                top: 0;
                left: 0;
                height: 100%;
                width: 100%;
                object-fit: cover;
            }
        }

        .cs-wave {
            width: (768/16rem);
            height: auto;
            display: block;
            position: absolute;
            left: 50%;
            bottom: -1px;
            transform: translateX(-50%);
            z-index: -1;
        }
    }
}

@media only screen and (min-width: 48rem) {
    #banner-843 .cs-wave {
        width: 100%;
        left: 0;
        transform: none;
    }
}

@media only screen and (min-width: 0rem) {
    body.dark-mode #banner-843 .cs-wave path {
        fill: var(--dark);
    }
}

/*-- -------------------------- -->
<---       Diensten Overview    -->
<--- -------------------------- -*/

@media only screen and (min-width: 0rem) {
    #diensten-overview {
        padding: var(--sectionPadding);

        .cs-container {
            width: 100%;
            max-width: (1280/16rem);
            margin: auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: clamp(3rem, 6vw, 4rem);
        }

        .cs-content {
            text-align: center;
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .cs-card-group {
            width: 100%;
            margin: 0;
            padding: 0;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
            gap: clamp(1rem, 2vw, 1.5rem);
        }

        .cs-item {
            list-style: none;
        }

        .cs-link {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: (12/16rem);
            padding: clamp(1.5rem, 3vw, 2rem);
            height: 100%;
            box-sizing: border-box;
            background-color: #fff;
            border-radius: (16/16rem);
            border: 1px solid #e8e8e8;
            text-decoration: none;
            transition: border-color 0.3s, box-shadow 0.3s;

            &:hover {
                border-color: var(--primary);
                box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            }
        }

        .cs-h3 {
            font-size: (20/16rem);
            font-weight: 700;
            margin: 0;
            color: var(--headerColor);
        }

        .cs-item-text {
            font-size: (15/16rem);
            line-height: 1.6em;
            margin: 0;
            color: var(--bodyTextColor);
            flex: 1;
        }

        .cs-cta {
            font-size: (14/16rem);
            font-weight: 700;
            color: var(--primary);
        }
    }
}

@media only screen and (min-width: 0rem) {
    body.dark-mode #diensten-overview {
        .cs-link {
            background-color: rgba(0,0,0,0.2);
            border-color: rgba(255,255,255,0.15);
        }

        .cs-title, .cs-h3 { color: var(--bodyTextColorWhite); }
        .cs-text, .cs-item-text { color: var(--bodyTextColorWhite); opacity: 0.8; }
    }
}
</style>
