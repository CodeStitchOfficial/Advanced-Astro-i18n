<script>
    // FAQ tab switching
    const options = document.querySelectorAll('#faq-2066 .cs-option');
    const faqGroups = document.querySelectorAll('#faq-2066 .cs-faq-group');

    options.forEach(option => {
        option.addEventListener('click', () => {
            const filter = option.getAttribute('data-filter');

            // Update active tab
            options.forEach(o => o.classList.remove('cs-active'));
            option.classList.add('cs-active');

            // Show matching FAQ group, hide others
            faqGroups.forEach(group => {
                if (group.getAttribute('data-category') === filter) {
                    group.classList.remove('cs-hidden');
                } else {
                    group.classList.add('cs-hidden');
                }
            });
        });
    });

    // FAQ accordion
    const faqItems = document.querySelectorAll('#faq-2066 .cs-faq-item');

    faqItems.forEach(item => {
        const button = item.querySelector('.cs-button');
        button.addEventListener('click', () => {
            const isActive = item.classList.contains('active');
            // Close all open items
            faqItems.forEach(i => i.classList.remove('active'));
            // Toggle clicked item
            if (!isActive) {
                item.classList.add('active');
            }
        });
    });
</script>

